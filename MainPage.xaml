<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrafficEscape2.MainPage">
    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Score and Lives -->
        <Grid Grid.Row="0" BackgroundColor="#1a1a1a" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="ScoreLabel" 
                Text="{Binding Score, StringFormat='Score : {0}'}" 
                   TextColor="{AppThemeBinding Light=red, Dark=White}"

                
                FontSize="20" 
                FontAttributes="Bold"
                VerticalOptions="Center"
                HorizontalOptions="Start"/>

            <Button x:Name="SettingsButton"
                 Grid.Column="0"
                 Text="Settings"
                 TextColor="{AppThemeBinding Light=Black, Dark=White}"
BackgroundColor="{AppThemeBinding Light=Blue, Dark=Black}"
                 FontAttributes="Bold"
                 WidthRequest="100"
                 Clicked="SettingsButton_ClickedAsync"/>

            <Button x:Name="StartButton"
                 Grid.Column="1"
                 Text="START"
                 TextColor="{AppThemeBinding Light=black, Dark=White}"
BackgroundColor="{AppThemeBinding Light=#00ff00, Dark=Black}"
                 FontAttributes="Bold"
                 WidthRequest="100"
                 Clicked="OnStartClicked"/>

               

            <Label x:Name="LivesLabel" 
                Grid.Column="2"
                Text="Lives: 3" 
                TextColor="{AppThemeBinding Light=red, Dark=White}"

                FontSize="20" 
                FontAttributes="Bold"
                VerticalOptions="Center"
                HorizontalOptions="End"/>

            
        </Grid>
        <Image Source="roadpaint.png" Aspect="Fill" Grid.Row="1" ZIndex="-1" />
        <!-- Game Canvas -->
        
        <AbsoluteLayout x:Name="GameCanvas" 
                    Grid.Row="1">
            <Label
            x:Name="CountdownLabel"
            Text=""
            FontSize="72"
            TextColor="White"
            FontAttributes="Bold"
            IsVisible="False"
            AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
            AbsoluteLayout.LayoutFlags="PositionProportional" />
           
        </AbsoluteLayout>

        <!-- Game Over Overlay -->
        <Grid x:Name="GameOverOverlay" 
           Grid.RowSpan="2"
           BackgroundColor="#CC000000"
           IsVisible="False">
            <VerticalStackLayout HorizontalOptions="Center" 
                            VerticalOptions="Center"
                            Spacing="20">
                <Label Text="GAME OVER" 
                    TextColor="{AppThemeBinding Light=red, Dark=White}"
                    FontSize="48" 
                    FontAttributes="Bold"
                    HorizontalOptions="Center"/>
                <Button Text="PLAY AGAIN"
                                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
BackgroundColor="{AppThemeBinding Light=#00ff00, Dark=Black}"
                    FontAttributes="Bold"
                    WidthRequest="150"
                    Clicked="OnPlayAgainClicked"/>
                <Button x:Name="SettingsButton2"
                     Text="Settings"
                                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
BackgroundColor="{AppThemeBinding Light=blue, Dark=Black}"
                     FontAttributes="Bold"
                     WidthRequest="150"
                     Clicked="SettingsButton_ClickedAsync"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
